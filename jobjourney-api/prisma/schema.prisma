datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String?
  googleId        String?  @unique
  name            String?
  avatarUrl       String?
  applicationGoal Int      @default(25)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)

  tenantUsers  TenantUser[]
  jobsCreated  Job[]    @relation("JobsCreatedBy")
  jobStatusChanges JobStatusHistory[] @relation("JobStatusChangedBy")
  passwordResetTokens PasswordResetToken[]
  monthlyGoals MonthlyGoal[]
  conversationParticipants ConversationParticipant[] @relation("ConversationParticipantUser")
  messagesSent Message[] @relation("MessageSender")
  invitesSent  TenantInvite[] @relation("TenantInvitesSent")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user      User     @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

model Tenant {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenantUsers   TenantUser[]
  jobs          Job[]
  conversations Conversation[]
  invites       TenantInvite[]
}

model TenantUser {
  id        String   @id @default(uuid())
  userId    String
  role      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
}

enum ApplicationStatus {
  INTERESTED
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  GHOSTED
}

model Job {
  id              String             @id @default(uuid())
  tenantId        String
  createdByUserId String

  company         String
  role            String
  status          ApplicationStatus  @default(INTERESTED)
  dateApplied     DateTime

  description     String?
  location        String?
  salary          String?
  link            String?
  notes           String?

  // Interview scheduling
  interviewDate            DateTime?          // Date and time of scheduled interview
  interviewReminderEnabled Boolean            @default(false)
  interviewReminderSentAt  DateTime?          // When interview reminder was sent

  // Extension/reminder fields
  source          String?            // 'linkedin', 'indeed', 'glassdoor', 'manual', 'extension'
  externalJobId   String?            // External job ID for deduplication
  followUpDate    DateTime?          // When to send follow-up reminder
  reminderEnabled Boolean            @default(false)
  reminderSentAt  DateTime?          // When reminder was last sent

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  createdByUser   User               @relation("JobsCreatedBy", fields: [createdByUserId], references: [id])
  statusHistory   JobStatusHistory[]

  @@index([tenantId])
  @@index([createdByUserId])
  @@index([status])
  @@index([dateApplied])
  @@index([followUpDate])
  @@index([interviewDate])
  @@index([tenantId, externalJobId])
}


model MonthlyGoal {
  id        String   @id @default(uuid())
  userId    String
  month     Int      // 1-12
  year      Int      // e.g. 2026
  target    Int      @default(25)
  met       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@index([userId])
}

model JobStatusHistory {
  id              String             @id @default(uuid())
  jobId           String
  status          ApplicationStatus
  notes           String?
  changedAt       DateTime
  changedByUserId String?

  job             Job                @relation(fields: [jobId], references: [id])
  changedByUser   User?              @relation("JobStatusChangedBy", fields: [changedByUserId], references: [id])

  @@index([jobId])
  @@index([status])
  @@index([changedAt])
}

model Conversation {
  id            String    @id @default(uuid())
  tenantId      String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant       Tenant                    @relation(fields: [tenantId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationParticipantUser", fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model TenantInvite {
  id              String    @id @default(uuid())
  tenantId        String
  email           String
  token           String    @unique
  invitedByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  invitedBy User   @relation("TenantInvitesSent", fields: [invitedByUserId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([token])
}
