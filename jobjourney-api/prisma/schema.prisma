datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String?
  googleId        String?  @unique
  name            String?
  applicationGoal Int      @default(25)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)

  tenantUsers  TenantUser[]
  jobsCreated  Job[]    @relation("JobsCreatedBy")
  jobStatusChanges JobStatusHistory[] @relation("JobStatusChangedBy")
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user      User     @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

model Tenant {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenantUsers TenantUser[]
  jobs        Job[]
}

model TenantUser {
  id        String   @id @default(uuid())
  userId    String
  role      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
}

enum ApplicationStatus {
  INTERESTED
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  GHOSTED
}

model Job {
  id              String             @id @default(uuid())
  tenantId        String
  createdByUserId String

  company         String
  role            String
  status          ApplicationStatus  @default(INTERESTED)
  dateApplied     DateTime

  description     String?
  location        String?
  salary          String?
  link            String?
  notes           String?

  // Extension/reminder fields
  source          String?            // 'linkedin', 'indeed', 'glassdoor', 'manual', 'extension'
  externalJobId   String?            // External job ID for deduplication
  followUpDate    DateTime?          // When to send follow-up reminder
  reminderEnabled Boolean            @default(false)
  reminderSentAt  DateTime?          // When reminder was last sent

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  createdByUser   User               @relation("JobsCreatedBy", fields: [createdByUserId], references: [id])
  statusHistory   JobStatusHistory[]

  @@index([tenantId])
  @@index([createdByUserId])
  @@index([status])
  @@index([dateApplied])
  @@index([followUpDate])
  @@index([tenantId, externalJobId])
}


model JobStatusHistory {
  id              String             @id @default(uuid())
  jobId           String
  status          ApplicationStatus
  notes           String?
  changedAt       DateTime
  changedByUserId String?

  job             Job                @relation(fields: [jobId], references: [id])
  changedByUser   User?              @relation("JobStatusChangedBy", fields: [changedByUserId], references: [id])

  @@index([jobId])
  @@index([status])
  @@index([changedAt])
}
